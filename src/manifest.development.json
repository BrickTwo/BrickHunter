{
    "manifest_version": 3,
    "name": "BrickHunter Dev",
    "description": "BrickHunter Dev",
    "version": "2.0.7",
    "background": {
        "service_worker": "/js/background.js"
    },
    "host_permissions" : [
        "https://brichunter-web-svc.azurewebsites.net/*",
        "https://localhost:7141/*",
        "https://www.lego.com/*"
    ],
    "permissions": [
        "activeTab",
        "cookies"
    ],
    "action": {
        "default_title": "BrickHunter Dev"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}